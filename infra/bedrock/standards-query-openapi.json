{
  "openapi": "3.0.3",
  "info": {
    "title": "StandardsQuery Action Group",
    "description": "Action group for querying early learning standards data from the Standards Database. Provides operations to list available states, age bands for a state, and indicators matching a state and age band.",
    "version": "1.0.0"
  },
  "paths": {
    "/getAvailableStates": {
      "get": {
        "operationId": "getAvailableStates",
        "summary": "Get available states",
        "description": "Returns a list of state codes for which the Standards Database contains early learning standards data.",
        "responses": {
          "200": {
            "description": "List of available state codes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "states": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "description": "Two-letter state code (e.g. MA, CA, NY)"
                      },
                      "description": "List of state codes that have standards data"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getAgeBands": {
      "get": {
        "operationId": "getAgeBands",
        "summary": "Get age bands for a state",
        "description": "Returns a list of age bands available for a given state. Each age band represents a developmental range that has associated indicators in the Standards Database.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Two-letter state code (e.g. MA, CA, NY)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of age bands for the specified state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ageBands": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "description": "Age band label (e.g. Infant, Toddler, Pre-K)"
                      },
                      "description": "List of age bands with standards data for this state"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getIndicators": {
      "get": {
        "operationId": "getIndicators",
        "summary": "Get indicators for a state and age band",
        "description": "Returns early learning indicators matching the specified state and age band. Each indicator includes its code, description, domain, strand, and sub-strand information.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Two-letter state code (e.g. MA, CA, NY)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ageBand",
            "in": "query",
            "required": true,
            "description": "Age band label (e.g. Infant, Toddler, Pre-K)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of indicators matching the state and age band",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "indicators": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Indicator"
                      },
                      "description": "List of matching indicators"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Indicator": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Unique indicator code (e.g. MA.PK.1.2)"
          },
          "description": {
            "type": "string",
            "description": "Full text description of the indicator"
          },
          "domain_name": {
            "type": "string",
            "description": "Learning domain name (e.g. Mathematics, Language)"
          },
          "strand_name": {
            "type": "string",
            "nullable": true,
            "description": "Strand name within the domain (e.g. Number Sense)"
          },
          "sub_strand_name": {
            "type": "string",
            "nullable": true,
            "description": "Sub-strand name within the strand"
          },
          "age_band": {
            "type": "string",
            "description": "Age band this indicator belongs to"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message describing what went wrong"
          }
        }
      }
    }
  }
}